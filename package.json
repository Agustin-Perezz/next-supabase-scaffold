{
  "name": "next-scaffold",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "supabase db reset && playwright test",
    "test:ui": "supabase db reset && playwright test --ui",
    "test:ci": "playwright test",
    "test:install": "playwright install --with-deps chromium",
    "test:show-report": "npx monocart show-report ./coverage/tests/monocart-report.html",
    "coverage:show-report": "npx monocart show-report ./coverage/tests/v8/index.html",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:push": "supabase db push",
    "supabase:reset": "supabase db reset",
    "supabase:gen-types": "supabase gen types --typescript --project-id ypdlrfoioxdlcowdjpiz --schema public > src/infrastructure/database/postgres/database.types.ts",
    "prepare": "husky"
  },
  "nano-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc,css}": "biome check --staged --no-errors-on-unmatched"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.110.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@playwright/test": "^1.61.1",
    "@sentry/nextjs": "^10.63.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "monocart-reporter": "^2.12.2",
    "nano-staged": "^1.0.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
